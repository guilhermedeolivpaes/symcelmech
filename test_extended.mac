kill(all)$
ratprint: false$
load("symcelmech.mac")$

/* ================================================================
   TEST 1: Backward compatibility -- 8 variables (original case)
   Reproduces the PB of the J2 geopotential with third-body terms
   ================================================================ */
print("=== TEST 1: 8 variables (backward compatibility) ===")$

setup_extended_pairs([l_3, theta], [n_3, w_rot])$
vars_8: [l, g, h, tau, L, G, H, T]$

/* Fictitious Hamiltonian depending on f and the pair (tau, T) */
A1: k_j2 / r^2 * (3*sin_i^2 * sin(f+g)^2 - 1)$
B1: T + sin(l_3) * G$

pb_8: pb_closed_form(A1, B1, vars_8)$
print("PB 8 vars (nonzero?):", is(pb_8 # 0))$

/* antisymmetry check */
pb_8_rev: pb_closed_form(B1, A1, vars_8)$
print("Antisymmetry 8 vars (must be 0):", ratsimp(pb_8 + pb_8_rev))$

